nline-block;min-width:52px;text-align:center;padding:3px 6px;border-radius:5px;font-size:10px;background:#f5f5f5;margin:2px 4px 2px 0;'> Temp<br/><b>-10.3&deg; a -9.9&deg;C</b></span><span style='display:inline-block;min-width:52px;text-align:center;padding:3px 6px;border-radius:5px;font-size:10px;background:#f5f5f5;margin:2px 4px 2px 0;'> Viento<br/><b>29 km/h</b></span></div></div><div style='border-left:5px solid #e6b800;background:#f7f7f7;border-radius:6px;padding:8px 10px;margin-bottom:6px;'><div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;'><b style='font-size:13px;'>+6 a 12h</b><span style='background:#e6b800;color:#000;font-size:10px;font-weight:bold;padding:2px 8px;border-radius:10px;'>Alerta amarilla</span></div><div style='display:flex;flex-wrap:wrap;gap:4px;font-size:11px;'><span style='display:inline-block;min-width:52px;text-align:center;padding:3px 6px;border-radius:5px;font-size:10px;background:#f5f5f5;margin:2px 4px 2px 0;'> ECMWF<br/><b>14.4 mm</b></span><span style='display:inline-block;min-width:52px;text-align:center;padding:3px 6px;border-radius:5px;font-size:10px;background:#f5f5f5;margin:2px 4px 2px 0;'> GFS<br/><b>16.4 mm</b></span><span style='display:inline-block;min-width:52px;text-align:center;padding:3px 6px;border-radius:5px;font-size:10px;background:#f5f5f5;margin:2px 4px 2px 0;'> ICON<br/><b>13.8 mm</b></span><span style='display:inline-block;min-width:52px;text-align:center;padding:3px 6px;border-radius:5px;font-size:10px;background:#f5f5f5;margin:2px 4px 2px 0;'> Isoterma<br/><b>1910 m</b></span><span style='display:inline-block;min-width:52px;text-align:center;padding:3px 6px;border-radius:5px;font-size:10px;background:#f5f5f5;margin:2px 4px 2px 0;'> Temp<br/><b>-10&deg; a -8.8&deg;C</b></span><span style='display:inline-block;min-width:52px;text-align:center;padding:3px 6px;border-radius:5px;font-size:10px;background:#f5f5f5;margin:2px 4px 2px 0;'> Viento<br/><b>59 km/h</b></span></div><